# Grants unprivileged access to hidraw nodes for Logitech devices LogiTux
# supports, so the app doesn't need to run as root.
#
# Installed to /etc/udev/rules.d/99-logitux.rules by install.sh.

# Litra Glow
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="c900", MODE="0666"
# Litra Beam
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="c901", MODE="0666"
