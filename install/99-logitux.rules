# Grants unprivileged access to hidraw nodes for Logitech devices LogiTux
# supports, so the app doesn't need to run as root.
#
# Installed to /etc/udev/rules.d/99-logitux.rules by install.sh.

# Litra Glow
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="c900", MODE="0666"
# Litra Beam
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="c901", MODE="0666"

# G Pro Wireless, via its Lightspeed USB receiver
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="c539", MODE="0666"
# G Pro Wireless, connected directly (wired/Bluetooth)
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="4079", MODE="0666"

# PRO X Wireless Gaming Headset
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="0aba", MODE="0666"

# Virtual input device LogiTux creates for button remapping (see
# internal/uinput). Only needed if you use that feature.
KERNEL=="uinput", MODE="0666"
